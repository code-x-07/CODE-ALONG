PISTON_BASE_URL=http://localhost:2000
# Optional if you have a private/authorized upstream.
PISTON_API_KEY=

# Used by Vercel API routes or the local app server.
# In Vercel, add these in Project Settings -> Environment Variables.

# Optional production web server port for server.mjs.
PORT=3000

# Basic abuse protection for shared execution.
EXECUTION_RATE_LIMIT_MAX_REQUESTS=30
EXECUTION_RATE_LIMIT_WINDOW_MS=60000
MAX_REQUEST_BODY_BYTES=262144
